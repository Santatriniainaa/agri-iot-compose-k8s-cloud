# ─── agri-iot-compose-k8s-cloud — variables d'environnement ───────────────────────────────
# Copier ce fichier en `.env` avant de lancer : cp .env.example .env

# InfluxDB (time-series database)
INFLUX_ORG=agri-iot-compose-k8s-cloud
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=agri-iot-compose-k8s-cloud-dev-token-change-me-0123456789
INFLUX_USERNAME=admin
INFLUX_PASSWORD=agri-iot-compose-k8s-cloud123
# Rétention du bucket brut (0s = infini). Downsampling 1h → bucket *_downsampled.
INFLUX_RETENTION=30d
INFLUX_DOWNSAMPLE_RETENTION=90d

# Grafana (dashboards)
GRAFANA_USER=admin
GRAFANA_PASSWORD=agri-iot-compose-k8s-cloud

# MQTT broker (authentification login/mot de passe activée)
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=agri-iot-compose-k8s-cloud
MQTT_PASSWORD=agri-iot-compose-k8s-cloud-mqtt-change-me

# Simulation
SITE=farm01
PARCELS=zoneA,zoneB,zoneC
PUBLISH_INTERVAL=2          # secondes entre deux salves de mesures
ANOMALY_PROB=0.01          # probabilité d'injecter une anomalie (test edge)

# Edge service
WINDOW_SECONDS=5           # fenêtre d'agrégation (alignée 5s : Telegraf flush + refresh Grafana)
MOISTURE_THRESHOLD=30      # %VWC en-dessous duquel irriguer
RAIN_SKIP_MM=2             # si pluie cumulée > seuil sur la fenêtre, pas d'irrigation

# Météo (weather-service → API Open-Meteo, gratuite et sans clé)
WEATHER_LAT=-18.8792       # latitude du site (défaut : Antananarivo, Madagascar)
WEATHER_LON=47.5079        # longitude du site
WEATHER_POLL_INTERVAL=60   # secondes entre deux relevés météo
# WEATHER_API_URL=https://api.open-meteo.com/v1/forecast   # (optionnel) URL de l'API

# API (FastAPI)
# Origines CORS autorisées pour la PWA (client navigateur). CSV ; "*" = tout autoriser.
# Ex. en prod : CORS_ORIGINS=http://localhost:8080,https://agri.exemple.com
CORS_ORIGINS=*
# Authentification JWT (posture démo : un utilisateur paramétré ci-dessous)
API_AUTH_USER=agri
API_AUTH_PASSWORD=agri-iot-demo
JWT_SECRET=agri-iot-compose-k8s-cloud-jwt-change-me-0123456789   # À CHANGER en production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720      # durée de validité du token (12 h)

# PWA (application mobile Angular)
# URL de l'API vue depuis le NAVIGATEUR (injectée au runtime dans config.json).
PWA_API_BASE_URL=http://localhost:8000
