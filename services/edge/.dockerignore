# Contexte de build minimal — n'envoyer au démon Docker que le strict nécessaire.

# Bytecode / caches Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environnements virtuels
*-env/
.venv/
venv/
env/

# Tests & couverture
tests/
.coverage
coverage/
htmlcov/

# Métadonnées de build / dépôt
Dockerfile
.dockerignore
.git
.gitignore
*.md

# Logs / secrets / divers
*.log
.env
.DS_Store
