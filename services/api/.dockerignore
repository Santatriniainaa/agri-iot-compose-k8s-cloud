# Contexte de build minimal — n'envoyer au démon Docker que le nécessaire.
__pycache__/
*.py[cod]
*$py.class

# Environnements virtuels (ne jamais copier dans l'image)
*-env/
.venv/
venv/
env/

# Modèles ML : (re)générés au démarrage par entrypoint.sh
models/
*.pkl
*.joblib

# Caches outils
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs / divers
*.log
.env
.DS_Store
