{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js",
          "/media/*.woff2",
          "/media/*.woff"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/icons/**", "/*.(svg|png|webp)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-data",
      "urls": ["**/api/v1/**", "**/health"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 200,
        "maxAge": "1d",
        "timeout": "5s"
      }
    }
  ]
}
